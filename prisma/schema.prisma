generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String?
  avatar    String?
  createdAt DateTime @default(now())

  roomsCreated        Room[]               @relation("RoomCreator")
  memberships         RoomMember[]
  expensesPaid        Expense[]           @relation("ExpensesPaidBy")
  expenseParticipates ExpenseParticipant[]
  settlementsGiven    Settlement[]        @relation("SettlementsFrom")
  settlementsReceived Settlement[]         @relation("SettlementsTo")
  incomes             Income[]
  budgets             Budget[]
  subscriptions       Subscription[]
  activities          Activity[]           @relation("ActivityActor")
}

model Room {
  id          String   @id @default(cuid())
  roomName    String
  description String?
  currency    String   @default("USD")
  inviteCode  String   @unique @default(cuid())
  createdAt   DateTime @default(now())

  createdBy String
  creator   User       @relation("RoomCreator", fields: [createdBy], references: [id])

  members    RoomMember[]
  expenses   Expense[]
  categories Category[]
  settlements Settlement[]
  budgets    Budget[]
  activities Activity[]
}

model RoomMember {
  id     String @id @default(cuid())
  role   String @default("member") // "admin" | "member"

  roomId String
  userId String

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
}

model Category {
  id     String  @id @default(cuid())
  name   String
  type   String  @default("expense") // "expense" | "income"
  roomId String? // null = default (app-wide), set = room-specific

  room      Room?     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  expenses  Expense[]
  incomes   Income[]
  budgets   Budget[]
}

model Expense {
  id         String   @id @default(cuid())
  title      String
  amount     Float
  date       DateTime @default(now())
  notes      String?
  splitType  String   @default("EQUAL") // EQUAL | EXACT | PERCENTAGE

  roomId     String
  room       Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  paidById  String
  paidBy    User     @relation("ExpensesPaidBy", fields: [paidById], references: [id])

  participants ExpenseParticipant[]

  createdAt DateTime @default(now())
}

model ExpenseParticipant {
  id         String  @id @default(cuid())
  expenseId  String
  userId     String
  amountOwed Float
  percentage Float? // for PERCENTAGE split, store original %

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([expenseId, userId])
}

model Settlement {
  id         String   @id @default(cuid())
  amount     Float
  date       DateTime @default(now())

  roomId     String
  room       Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  fromUserId String
  fromUser   User     @relation("SettlementsFrom", fields: [fromUserId], references: [id])
  toUserId   String
  toUser     User     @relation("SettlementsTo", fields: [toUserId], references: [id])

  createdAt  DateTime @default(now())
}

model Income {
  id         String   @id @default(cuid())
  title      String
  amount     Float
  date       DateTime @default(now())
  notes      String?

  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  createdAt  DateTime @default(now())
}

model Budget {
  id         String  @id @default(cuid())
  amount     Float   // budget limit
  period     String  @default("MONTHLY") // MONTHLY | YEARLY

  userId     String
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  roomId     String? // null = personal budget
  room       Room?   @relation(fields: [roomId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())

  @@unique([userId, categoryId])
}

model Subscription {
  id              String   @id @default(cuid())
  name            String
  price           Float
  billingCycle    String   @default("MONTHLY") // MONTHLY | YEARLY
  nextPaymentDate DateTime

  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  notes           String?
  createdAt       DateTime @default(now())
}

model Activity {
  id        String   @id @default(cuid())
  type      String   // MEMBER_JOINED, EXPENSE_ADDED, SETTLEMENT_COMPLETED, etc.
  metadata  Json?    // { roomName?, expenseTitle?, amount?, ... }

  roomId    String?
  room      Room?    @relation(fields: [roomId], references: [id], onDelete: Cascade)

  userId    String
  user      User     @relation("ActivityActor", fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}
